            "description": "Files to add (for 'add' operation). Use ['.'] for all files."
          },
          "message": {
            "type": "string",
            "description": "Commit message (required for 'commit' operation)"
          },
          "path": {
            "type": "string",
            "description": "Path to diff (optional for 'diff' operation)"
          }
        },
        "required": [
          "operation"
        ]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "exit_loop",
      "description": "Exits the Ralph loop only when every entry in tasks.json is completed, skipped, or blocked. If work remains, returns a refusal JSON payload (no exit). Call tasks list/get_next and continue."
    }
  }
]
