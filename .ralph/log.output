            "description": "The operation to perform"
          },
          "path": {
            "type": "string",
            "description": "Relative path to the file or directory"
          },
          "content": {
            "type": "string",
            "description": "Content to write (required for 'write' operation)"
          }
        },
        "required": [
          "operation",
          "path"
        ]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "git",
      "description": "Git operations: status, add, commit, diff for version control.",
      "parameters": {
        "type": "object",
        "properties": {
          "operation": {
            "type": "string",
            "enum": [
              "status",
              "add",
              "commit",
              "diff"
            ],
            "description": "The git operation to perform"
          },
          "files": {
            "type": "array",
            "items": {
