            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Files to add (for 'add' operation). Use ['.'] for all files."
          },
          "message": {
            "type": "string",
            "description": "Commit message (required for 'commit' operation)"
          },
          "path": {
            "type": "string",
            "description": "Path to diff (optional for 'diff' operation)"
          }
