                "items": {
                  "type": "string"
                },
                "description": "Files created during this task"
              },
              "files_modified": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Files modified during this task"
              },
              "test_results": {
                "type": "object",
                "properties": {
                  "passed": {
                    "type": "integer"
                  },
                  "failed": {
                    "type": "integer"
                  },
                  "skipped": {
                    "type": "integer"
                  }
